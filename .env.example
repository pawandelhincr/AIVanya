# Copy to project root as .env

# paper | live
TRADING_MODE=paper
# zerodha | dhan  (used when TRADING_MODE=live)
ACTIVE_BROKER=zerodha
PAPER_STARTING_CASH=500000
WEEKLY_TARGET_RETURN_PCT=8.0
MAX_RISK_PER_TRADE_PCT=1.0

# ── Zerodha Kite Connect ───────────────────────────────────
# https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
KITE_USER_ID=
# Redirect URL in Kite app:
#   http://127.0.0.1:8001/api/broker/zerodha/callback

# ── DhanHQ ─────────────────────────────────────────────────
# web.dhan.co → Profile → Access DhanHQ APIs
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
# Optional OAuth app (if using DhanLogin flow)
DHAN_APP_ID=
DHAN_APP_SECRET=

# Optional LLM polish (Hinglish replies)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Subscription (₹999 / 3 months, 7-day trial) ────────────
ALLOW_DEMO_SUBSCRIBE=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
